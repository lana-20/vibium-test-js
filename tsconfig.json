{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "vitest.setup.ts", "jest.setup.ts", "tests/**/*", "vitest.config.ts", "vitest.d.ts"]
}
